<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% for (let i = 0; i < messages.length; i++) { %>
          <p class="mb-0"><%= messages[i] %></p>
        <% } %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% for (let i = 0; i < errors.length; i++) { %>
          <p class="mb-0"><%= errors[i] %></p>
        <% } %>
      </div>
    <% } %>

    <div class="page-section">
      <h1>Admin Dashboard</h1>
      <p>Welcome, <%= user.username %> (Admin)</p>

      <a href="/products" class="btn btn-primary">
        Manage Products
      </a>
    </div>

    <div class="page-section">
      <h2>Registered Users</h2>

      <div class="table-responsive">
        <table class="table table-striped table-bordered">
          <thead class="table-dark">
            <tr>
              <th>User ID</th>
              <th>Username</th>
              <th>Email</th>
              <th>Registered At</th>
            </tr>
          </thead>

          <tbody>
            <% if (recentUsers && recentUsers.length > 0) { %>
              <% for (let i = 0; i < recentUsers.length; i++) { %>
                <tr>
                  <td><%= recentUsers[i].user_id %></td>
                  <td><%= recentUsers[i].username %></td>
                  <td><%= recentUsers[i].email %></td>
                  <td><%= recentUsers[i].registered_at %></td>
                </tr>
              <% } %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center">
                  No registered users found.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>