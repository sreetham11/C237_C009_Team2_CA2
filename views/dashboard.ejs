<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buyer Dashboard - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% for (let i = 0; i < messages.length; i++) { %>
          <p class="mb-0"><%= messages[i] %></p>
        <% } %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% for (let i = 0; i < errors.length; i++) { %>
          <p class="mb-0"><%= errors[i] %></p>
        <% } %>
      </div>
    <% } %>

    <div class="page-section text-center">
      <h1>Buyer Dashboard</h1>
      <p>Welcome, <%= user.username %> (<%= user.role %>)</p>

      <%- include('partials/profile-picture') %>

      <div class="mt-4">
        <a href="/cart" class="btn btn-primary me-2">
          View Cart
        </a>

        <a href="/products?myListings=true" class="btn btn-primary">
          Manage Listings
        </a>
      </div>
    </div>

    <% if (cartCount === 0) { %>

      <div class="page-section stat-empty mt-4">
        <p class="mb-3">
          Your cart is empty - browse products to add something!
        </p>

        <a href="/products" class="btn btn-success">
          Browse Products
        </a>
      </div>

    <% } else { %>

      <div class="row g-4 mt-4">
        <div class="col-md-6">
          <div class="page-section stat-card">
            <div class="stat-card-value">
              <%= cartCount %>
            </div>
            <div class="stat-card-label">
              Items in Cart
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="page-section stat-card">
            <div class="stat-card-value">
              $<%= cartTotal.toFixed(2) %>
            </div>
            <div class="stat-card-label">
              Cart Total Value
            </div>
          </div>
        </div>
      </div>

    <% } %>

    <% if (listingCount === 0) { %>

      <div class="page-section stat-empty mt-4">
        <p class="mb-3">
          No listings yet. Add your first product to get started.
        </p>

        <a href="/products/new" class="btn btn-success">
          Add Product
        </a>
      </div>

    <% } else { %>

      <div class="row g-4 mt-4">
        <div class="col-md-4">
          <div class="page-section stat-card">
            <div class="stat-card-value">
              <%= listingCount %>
            </div>
            <div class="stat-card-label">
              Active Listings
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="page-section stat-card">
            <div class="stat-card-value">
              <%= totalQuantity %>
            </div>
            <div class="stat-card-label">
              Total Inventory Quantity
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="page-section stat-card">
            <div class="stat-card-value">
              $<%= totalValue.toFixed(2) %>
            </div>
            <div class="stat-card-label">
              Total Inventory Value
            </div>
          </div>
        </div>
      </div>

    <% } %>

  </div>
</body>
</html>