<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ResellVault - Home</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% for (let i = 0; i < messages.length; i++) { %>
          <p class="mb-0"><%= messages[i] %></p>
        <% } %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% for (let i = 0; i < errors.length; i++) { %>
          <p class="mb-0"><%= errors[i] %></p>
        <% } %>
      </div>
    <% } %>

    <div class="page-section">
      <h1 class="hero-heading">Welcome to Resell<span class="accent-text">Vault</span><svg class="hero-heading-icon" viewBox="0 0 24 24" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg></h1>

      <p class="lead">
        The vault for collectors. Trading cards, collectibles and clothing, secured and verified.
      </p>

      <h3>Browse by category</h3>

      <div class="category-pills">
        <% [
          'Trading Cards',
          'Collectibles',
          'Clothing',
          'Shoes',
          'Accessories',
          'Electronics',
          'Others'
        ].forEach(function(category) { %>
          <form action="/searchProducts" method="POST">
            <input type="hidden" name="searchCategory" value="<%= category %>">
            <button type="submit" class="category-pill">
              <%= category %>
            </button>
          </form>
        <% }); %>
      </div>
    </div>

    <div class="row g-4 home-cards-row">
      <div class="col-md-4">
        <div class="page-section info-card h-100 mb-0">
          <div class="info-card-icon">
            <svg viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
          <h3>Find Products</h3>
          <p>Filter listings by exact product name, or narrow results down to a single category in seconds.</p>
          <div class="info-card-highlight">
            <strong>7 categories</strong> to search across, including Others.
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="page-section info-card h-100 mb-0">
          <div class="info-card-icon">
            <svg viewBox="0 0 24 24">
              <rect x="3" y="3" width="7" height="7" rx="1"></rect>
              <rect x="14" y="3" width="7" height="7" rx="1"></rect>
              <rect x="3" y="14" width="7" height="7" rx="1"></rect>
              <rect x="14" y="14" width="7" height="7" rx="1"></rect>
            </svg>
          </div>
          <h3>Browse Listings</h3>
          <p>Every active listing from every seller lives in one feed, covering trading cards, collectibles, shoes, apparel and more.</p>
          <div class="info-card-highlight">
            <strong>One feed</strong>, every seller, no separate storefronts to check.
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="page-section info-card h-100 mb-0">
          <div class="info-card-icon">
            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="8" r="4"></circle>
              <path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"></path>
            </svg>
          </div>
          <h3>Your Account</h3>
          <p>Buyers track orders and manage their cart from the dashboard. Sellers manage listings, monitor sales and update inventory.</p>
          <div class="info-card-highlight">
            <strong>Role-based</strong> dashboard that adapts to how you use ResellVault.
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>