<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">
      ResellVault
    </a>

    <% if (user) { %>
      <div class="mx-auto navbar-search">
        <form
          class="d-flex"
          action="/searchProducts"
          method="POST">

          <input
            class="form-control me-2"
            type="text"
            name="searchName"
            placeholder="Search exact product name">

          <input
            type="hidden"
            name="searchCategory"
            value="">

          <button
            class="btn btn-primary"
            type="submit">
            Search
          </button>
        </form>
      </div>
    <% } %>

    <div class="ms-auto">
      <% if (user) { %>
        <span class="text-light me-3">
          Hello, <%= user.username %>
        </span>

        <a
          href="/dashboard"
          class="btn btn-outline-light me-2">
          Dashboard
        </a>

        <a
          href="/logout"
          class="btn btn-danger">
          Logout
        </a>
      <% } else { %>
        <a
          href="/login"
          class="btn btn-outline-light me-2">
          Login
        </a>

        <a
          href="/register"
          class="btn btn-primary">
          Register
        </a>
      <% } %>
    </div>
  </div>
</nav>