<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">

  <div class="container-fluid">

    <a
      class="navbar-brand"
      href="/">

      ResellVault

    </a>

    <div class="mx-auto navbar-search">

      <form
        class="d-flex"
        action="/searchProducts"
        method="POST">

        <input
          class="form-control me-2"
          type="text"
          name="searchName"
          placeholder="Search product name">

        <input
          type="hidden"
          name="searchCategory"
          value="">

        <button
          class="btn btn-primary"
          type="submit">

          Search

        </button>

      </form>

    </div>

    <div class="ms-auto">

      <% if (user) { %>

        <a href="/dashboard" class="navbar-greeting text-light me-3">
          Hello, <%= user.username %>
        </a>

        <% if (
          user.role === 'buyer' ||
          user.role === 'seller' ||
          user.role === 'user' ||
          user.role === 'admin'
        ) { %>

          <a
            href="/cart"
            class="btn btn-success me-2">

            Cart

          </a>

        <% } %>

        <a
          href="/logout"
          class="btn btn-danger">

          Logout

        </a>

      <% } else { %>

        <a
          href="/login"
          class="btn btn-outline-light me-2">

          Login

        </a>

        <a
          href="/register"
          class="btn btn-primary">

          Register

        </a>

      <% } %>

    </div>

  </div>

</nav>

<style>

  .navbar-search {
    width: 50%;
  }

  .navbar-greeting {
    transition: opacity 0.15s ease;
  }

  .navbar-greeting:hover {
    opacity: 0.75;
  }

  @media screen and (max-width: 768px) {

    .navbar-search {
      width: 40%;
    }

  }

</style>