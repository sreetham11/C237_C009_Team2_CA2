<div class="profile-pic-wrap mt-3">

  <img
    src="/images/<%= user.profile_picture ? user.profile_picture : 'default-pfp.png' %>"
    alt="Profile Picture"
    class="profile-pic">

  <button
    type="button"
    class="profile-pic-edit-btn"
    aria-label="Edit profile picture"
    onclick="document.getElementById('profile-pic-form').classList.toggle('d-none')">

    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 20h9"></path>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
    </svg>

  </button>

</div>

<form
  id="profile-pic-form"
  class="profile-pic-form d-none mt-3"
  action="/profile/picture"
  method="POST"
  enctype="multipart/form-data">

  <input
    type="file"
    name="image"
    accept="image/*"
    class="form-control form-control-sm mb-2"
    required>

  <button type="submit" class="btn btn-sm btn-primary">
    Upload
  </button>

</form>
