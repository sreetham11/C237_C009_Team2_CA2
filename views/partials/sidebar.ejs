<div class="sidebar">

  <a href="/">
    Home
  </a>

  <a href="/products">
    Browse Products
  </a>

  <a href="/dashboard">
    My Dashboard
  </a>

  <% if (user) { %>

    <% if (user.role === 'seller') { %>

      <a href="/products/new">
        Add Product
      </a>

    <% } %>

    <% if (
      user.role === 'buyer' ||
      user.role === 'user'
    ) { %>

      <a href="/cart">
        Cart
      </a>

    <% } %>

  <% } %>

</div>