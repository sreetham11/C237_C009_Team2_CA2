<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Details - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">
    <div class="page-section">
      <h1><%= product.name %></h1>

      <% if (product.image) { %>
        <img
          src="/images/<%= product.image %>"
          alt="<%= product.name %>"
          class="product-image-large mb-3">
      <% } else { %>
        <p>No image</p>
      <% } %>

      <p><strong>Description:</strong> <%= product.description %></p>
      <p><strong>Category:</strong> <%= product.category %></p>
      <p><strong>Condition:</strong> <%= product.condition_type %></p>
      <p><strong>Quantity:</strong> <%= product.quantity %></p>
      <p><strong>Price:</strong> $<%= product.price %></p>
      <p><strong>Delivery Method:</strong> <%= product.delivery_method %></p>
      <p><strong>Meet-up Location:</strong> <%= product.meetup_location %></p>

      <a href="/products" class="btn btn-outline-dark">
        Back to Listings
      </a>

      <% if (
        user.role === 'admin' ||
        (
          user.role === 'seller' &&
          product.seller_id == user.user_id
        )
      ) { %>
        <a
          href="/editProduct/<%= product.product_id %>"
          class="btn btn-warning">
          Edit
        </a>
      <% } %>
    </div>
  </div>
</body>
</html>