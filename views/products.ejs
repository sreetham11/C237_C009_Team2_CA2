<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>ResellVault - All Products</title>
</head>

<body>

  <h1>ResellVault - All Products</h1>

  <% if (messages && messages.length > 0) { %>
    <p>
      <%= messages[0] %>
    </p>
  <% } %>

  <% if (errors && errors.length > 0) { %>
    <p>
      <%= errors[0] %>
    </p>
  <% } %>

  <!-- Search and filter form -->
  <h2>Search and Filter Products</h2>

  <form action="/searchProducts" method="POST">

    <p>
      <label for="searchName">Product Name:</label>

      <input
        type="text"
        id="searchName"
        name="searchName"
        placeholder="Enter exact product name">
    </p>

    <p>
      <label for="searchCategory">Category:</label>

      <select id="searchCategory" name="searchCategory">

        <option value="">All Categories</option>
        <option value="Trading Cards">Trading Cards</option>
        <option value="Collectibles">Collectibles</option>
        <option value="Clothing">Clothing</option>

      </select>
    </p>

    <button type="submit">
      Search
    </button>

    <a href="/products">
      Clear
    </a>

  </form>

  <hr>

  <h2>All Products</h2>

  <% if (products.length > 0) { %>

    <table border="1" cellpadding="8">

      <tr>
        <th>Name</th>
        <th>Image</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Category</th>
        <th>Edit</th>
        <th>Delete</th>
      </tr>

      <% for (let i = 0; i < products.length; i++) { %>

        <tr>

          <td>
            <%= products[i].name %>
          </td>

          <td>

            <% if (products[i].image) { %>

              <img
                src="/images/<%= products[i].image %>"
                alt="<%= products[i].name %>"
                width="100">

            <% } else { %>

              No image

            <% } %>

          </td>

          <td>
            $<%= products[i].price %>
          </td>

          <td>
            <%= products[i].quantity %>
          </td>

          <td>
            <%= products[i].category %>
          </td>

          <td>
            <a href="/editProduct/<%= products[i].product_id %>">
              Edit
            </a>
          </td>

          <td>

            <% if (
              user &&
              (
                user.role === 'admin' ||
                (
                  user.role === 'seller' &&
                  products[i].seller_id == user.user_id
                )
              )
            ) { %>

              <a
                href="/deleteProduct/<%= products[i].product_id %>"
                onclick="return confirm('Are you sure you want to delete this product?')">

                Delete

              </a>

            <% } else { %>

              -

            <% } %>

          </td>

        </tr>

      <% } %>

    </table>

  <% } else { %>

    <p>No products found.</p>

  <% } %>

</body>

</html>
