<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Products - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% for (let i = 0; i < messages.length; i++) { %>
          <p class="mb-0"><%= messages[i] %></p>
        <% } %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% for (let i = 0; i < errors.length; i++) { %>
          <p class="mb-0"><%= errors[i] %></p>
        <% } %>
      </div>
    <% } %>

    <div class="page-section">
      <h1>All Products</h1>

      <a href="/searchProducts" class="btn btn-outline-primary me-2">
        Search and Filter Products
      </a>

      <% if (user.role === 'seller') { %>
        <a href="/products/new" class="btn btn-success">
          Add Product
        </a>
      <% } %>
    </div>

    <div class="page-section">
      <% if (products.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-bordered table-striped align-middle">
            <thead class="table-dark">
              <tr>
                <th>Name</th>
                <th>Image</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Category</th>
                <th>View</th>
                <th>Edit</th>
                <th>Delete</th>
              </tr>
            </thead>

            <tbody>
              <% for (let i = 0; i < products.length; i++) { %>
                <tr>
                  <td><%= products[i].name %></td>

                  <td>
                    <% if (products[i].image) { %>
                      <img
                        src="/images/<%= products[i].image %>"
                        alt="<%= products[i].name %>"
                        class="product-image">
                    <% } else { %>
                      No image
                    <% } %>
                  </td>

                  <td>$<%= products[i].price %></td>
                  <td><%= products[i].quantity %></td>
                  <td><%= products[i].category %></td>

                  <td>
                    <a
                      href="/product/<%= products[i].product_id %>"
                      class="btn btn-info btn-sm">
                      View
                    </a>
                  </td>

                  <td>
                    <% if (
                      user.role === 'admin' ||
                      (
                        user.role === 'seller' &&
                        products[i].seller_id == user.user_id
                      )
                    ) { %>
                      <a
                        href="/editProduct/<%= products[i].product_id %>"
                        class="btn btn-warning btn-sm">
                        Edit
                      </a>
                    <% } else { %>
                      -
                    <% } %>
                  </td>

                  <td>
                    <% if (
                      user.role === 'admin' ||
                      (
                        user.role === 'seller' &&
                        products[i].seller_id == user.user_id
                      )
                    ) { %>
                      <a
                        href="/deleteProduct/<%= products[i].product_id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Are you sure you want to delete this product?')">
                        Delete
                      </a>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p>No products found.</p>
      <% } %>
    </div>
  </div>
</body>
</html>