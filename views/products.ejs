<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0">

  <title>Product Listings - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>

<body>

  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">

    <% if (messages && messages.length > 0) { %>

      <div class="alert alert-success">

        <% for (let i = 0; i < messages.length; i++) { %>

          <p class="mb-0">
            <%= messages[i] %>
          </p>

        <% } %>

      </div>

    <% } %>

    <% if (errors && errors.length > 0) { %>

      <div class="alert alert-danger">

        <% for (let i = 0; i < errors.length; i++) { %>

          <p class="mb-0">
            <%= errors[i] %>
          </p>

        <% } %>

      </div>

    <% } %>

    <div class="page-section">

      <h1>
        <% if (myListings) { %>
          My Listings
        <% } else { %>
          Product Listings
        <% } %>
      </h1>

      <% if (!myListings) { %>

        <h2 id="search-form" class="h4 mt-4">
          Search and Filter
        </h2>

        <form
          action="/searchProducts"
          method="POST"
          class="mt-3">

          <div class="row">

            <div class="col-md-6 mb-3">

              <label
                for="searchName"
                class="form-label">

                Product Name

              </label>

              <input
                type="text"
                id="searchName"
                name="searchName"
                class="form-control"
                value="<%= searchName %>"
                placeholder="Enter part of a product name">

            </div>

            <div class="col-md-4 mb-3">

              <label
                for="searchCategory"
                class="form-label">

                Category

              </label>

              <select
                id="searchCategory"
                name="searchCategory"
                class="form-select">

                <option value="">
                  All Categories
                </option>

                <option
                  value="Trading Cards"
                  <% if (searchCategory === 'Trading Cards') { %>
                    selected
                  <% } %>>

                  Trading Cards

                </option>

                <option
                  value="Collectibles"
                  <% if (searchCategory === 'Collectibles') { %>
                    selected
                  <% } %>>

                  Collectibles

                </option>

                <option
                  value="Clothing"
                  <% if (searchCategory === 'Clothing') { %>
                    selected
                  <% } %>>

                  Clothing

                </option>

                <option
                  value="Shoes"
                  <% if (searchCategory === 'Shoes') { %>
                    selected
                  <% } %>>

                  Shoes

                </option>

                <option
                  value="Accessories"
                  <% if (searchCategory === 'Accessories') { %>
                    selected
                  <% } %>>

                  Accessories

                </option>

                <option
                  value="Electronics"
                  <% if (searchCategory === 'Electronics') { %>
                    selected
                  <% } %>>

                  Electronics

                </option>

              </select>

            </div>

            <div class="col-md-2 mb-3 d-flex align-items-end">

              <button
                type="submit"
                class="btn btn-primary">

                Search

              </button>

            </div>

          </div>

          <a
            href="/products"
            class="btn btn-secondary">

            Clear

          </a>

        </form>

      <% } %>

    </div>

    <div class="page-section">

      <h2>
        <% if (myListings) { %>
          Your Listings
        <% } else { %>
          Products
        <% } %>
      </h2>

      <% if (products.length > 0) { %>

        <div class="table-responsive">

          <table class="table table-bordered table-striped align-middle">

            <thead class="table-dark">

              <tr>
                <th>Name</th>
                <th>Image</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Category</th>
                <th>Enlisted By</th>
                <th>View</th>
                <th>Edit</th>
                <th>Delete</th>
                <th>Cart</th>
              </tr>

            </thead>

            <tbody>

              <% for (let i = 0; i < products.length; i++) { %>

                <tr>

                  <td>
                    <%= products[i].name %>
                  </td>

                  <td>

                    <% if (products[i].image) { %>

                      <img
                        src="/images/<%= products[i].image %>"
                        alt="<%= products[i].name %>"
                        class="product-image">

                    <% } else { %>

                      No image

                    <% } %>

                  </td>

                  <td>
                    $<%= products[i].price %>
                  </td>

                  <td>
                    <%= products[i].quantity %>
                  </td>

                  <td>
                    <%= products[i].category %>
                  </td>

                  <td>
                    <%= products[i].seller_name %>
                  </td>

                  <td>

                    <a
                      href="/product/<%= products[i].product_id %>"
                      class="btn btn-info btn-sm">

                      View

                    </a>

                  </td>

                  <td>

                    <% if (
                      user &&
                      (
                        products[i].seller_id == user.user_id ||
                        (
                          user.role === 'admin' &&
                          products[i].seller_role === 'admin'
                        )
                      )
                    ) { %>

                      <a
                        href="/editProduct/<%= products[i].product_id %>"
                        class="btn btn-warning btn-sm">

                        Edit

                      </a>

                    <% } else { %>

                      -

                    <% } %>

                  </td>

                  <td>

                    <% if (
                      user &&
                      (
                        user.role === 'admin' ||
                        products[i].seller_id == user.user_id
                      )
                    ) { %>

                      <a
                        href="/deleteProduct/<%= products[i].product_id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Are you sure you want to delete this product?')">

                        Delete

                      </a>

                    <% } else { %>

                      -

                    <% } %>

                  </td>

                  <td>

                    <% if (
                      user &&
                      (user.role === 'buyer' ||
                      user.role === 'seller' ||
                      user.role === 'user' ||
                      user.role === 'admin')
                    ) { %>

                      <form
                        action="/cart/add/<%= products[i].product_id %>"
                        method="POST">

                        <button
                          type="submit"
                          class="btn btn-success btn-sm">

                          Add to Cart

                        </button>

                      </form>

                    <% } else { %>

                      -

                    <% } %>

                  </td>

                </tr>

              <% } %>

            </tbody>

          </table>

        </div>

      <% } else { %>

        <div class="alert alert-warning">
          <% if (myListings) { %>

            <p class="mb-3">
              You haven't listed any products yet.
            </p>

            <a href="/products/new" class="btn btn-success btn-sm">
              Add Product
            </a>

          <% } else { %>

            No matching products were found.

          <% } %>
        </div>

      <% } %>

    </div>

  </div>

</body>

</html>