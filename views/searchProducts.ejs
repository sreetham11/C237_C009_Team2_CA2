<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search Products - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">
    <div class="page-section">
      <h1>Search and Filter Products</h1>

      <form
        action="/searchProducts"
        method="POST"
        class="mt-4">

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="searchName" class="form-label">
              Product Name
            </label>

            <input
              type="text"
              class="form-control"
              id="searchName"
              name="searchName"
              value="<%= searchName %>"
              placeholder="Enter exact product name">
          </div>

          <div class="col-md-4 mb-3">
            <label for="searchCategory" class="form-label">
              Category
            </label>

            <select
              class="form-select"
              id="searchCategory"
              name="searchCategory">

              <option value="">All Categories</option>

              <option
                value="Trading Cards"
                <%= searchCategory === 'Trading Cards' ? 'selected' : '' %>>
                Trading Cards
              </option>

              <option
                value="Collectibles"
                <%= searchCategory === 'Collectibles' ? 'selected' : '' %>>
                Collectibles
              </option>

              <option
                value="Clothing"
                <%= searchCategory === 'Clothing' ? 'selected' : '' %>>
                Clothing
              </option>

              <option
                value="Shoes"
                <%= searchCategory === 'Shoes' ? 'selected' : '' %>>
                Shoes
              </option>

              <option
                value="Accessories"
                <%= searchCategory === 'Accessories' ? 'selected' : '' %>>
                Accessories
              </option>

              <option
                value="Electronics"
                <%= searchCategory === 'Electronics' ? 'selected' : '' %>>
                Electronics
              </option>
            </select>
          </div>

          <div class="col-md-2 mb-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary">
              Search
            </button>
          </div>
        </div>

        <a href="/searchProducts" class="btn btn-secondary">
          Clear
        </a>
      </form>
    </div>

    <div class="page-section">
      <h2>Search Results</h2>

      <% if (products.length > 0) { %>
        <div class="table-responsive mt-3">
          <table class="table table-bordered table-striped align-middle">
            <thead class="table-dark">
              <tr>
                <th>Name</th>
                <th>Image</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Category</th>
                <th>View</th>
                <th>Edit</th>
                <th>Delete</th>
              </tr>
            </thead>

            <tbody>
              <% for (let i = 0; i < products.length; i++) { %>
                <tr>
                  <td><%= products[i].name %></td>

                  <td>
                    <% if (products[i].image) { %>
                      <img
                        src="/images/<%= products[i].image %>"
                        alt="<%= products[i].name %>"
                        class="product-image">
                    <% } else { %>
                      No image
                    <% } %>
                  </td>

                  <td>$<%= products[i].price %></td>
                  <td><%= products[i].quantity %></td>
                  <td><%= products[i].category %></td>

                  <td>
                    <a
                      href="/product/<%= products[i].product_id %>"
                      class="btn btn-info btn-sm">
                      View
                    </a>
                  </td>

                  <td>
                    <% if (
                      user.role === 'admin' ||
                      (
                        user.role === 'seller' &&
                        products[i].seller_id == user.user_id
                      )
                    ) { %>
                      <a
                        href="/editProduct/<%= products[i].product_id %>"
                        class="btn btn-warning btn-sm">
                        Edit
                      </a>
                    <% } else { %>
                      -
                    <% } %>
                  </td>

                  <td>
                    <% if (
                      user.role === 'admin' ||
                      (
                        user.role === 'seller' &&
                        products[i].seller_id == user.user_id
                      )
                    ) { %>
                      <a
                        href="/deleteProduct/<%= products[i].product_id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Are you sure you want to delete this product?')">
                        Delete
                      </a>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="alert alert-warning mt-3">
          No matching products were found.
        </div>
      <% } %>

      <a href="/products" class="btn btn-outline-dark">
        Back to Listings
      </a>
    </div>
  </div>
</body>
</html>