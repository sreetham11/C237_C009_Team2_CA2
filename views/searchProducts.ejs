<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0">

  <title>Search Products - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet">

  <style>

    body {
      background-color: #f5f5f5;
    }

    .content {
      margin-left: 200px;
      padding: 90px 30px 30px;
    }

    .search-section {
      background-color: white;
      padding: 25px;
      border-radius: 10px;
      margin-bottom: 25px;
    }

    .results-section {
      background-color: white;
      padding: 25px;
      border-radius: 10px;
    }

    .product-image {
      width: 80px;
      height: 80px;
      object-fit: cover;
    }

  </style>

</head>

<body>

  <!-- Shared navbar -->
  <%- include('partials/navbar') %>

  <!-- Shared sidebar -->
  <%- include('partials/sidebar') %>

  <div class="content">

    <div class="search-section">

      <h1>
        <i class="bi bi-search me-2"></i>
        Search and Filter Products
      </h1>

      <form
        action="/searchProducts"
        method="POST"
        class="mt-4">

        <div class="row">

          <div class="col-md-6 mb-3">

            <label
              for="searchName"
              class="form-label">

              Product Name

            </label>

            <input
              type="text"
              class="form-control"
              id="searchName"
              name="searchName"
              value="<%= searchName %>"
              placeholder="Enter exact product name">

          </div>

          <div class="col-md-4 mb-3">

            <label
              for="searchCategory"
              class="form-label">

              Category

            </label>

            <select
              class="form-select"
              id="searchCategory"
              name="searchCategory">

              <option value="">
                All Categories
              </option>

              <option
                value="Trading Cards"
                <% if (searchCategory === 'Trading Cards') { %>
                  selected
                <% } %>>

                Trading Cards

              </option>

              <option
                value="Collectibles"
                <% if (searchCategory === 'Collectibles') { %>
                  selected
                <% } %>>

                Collectibles

              </option>

              <option
                value="Clothing"
                <% if (searchCategory === 'Clothing') { %>
                  selected
                <% } %>>

                Clothing

              </option>

            </select>

          </div>

          <div class="col-md-2 mb-3 d-flex align-items-end">

            <button
              type="submit"
              class="btn btn-primary me-2">

              <i class="bi bi-search"></i>
              Search

            </button>

          </div>

        </div>

        <a
          href="/searchProducts"
          class="btn btn-secondary">

          <i class="bi bi-arrow-counterclockwise"></i>
          Clear

        </a>

      </form>

    </div>

    <div class="results-section">

      <h2>
        Search Results
      </h2>

      <% if (products.length > 0) { %>

        <div class="table-responsive mt-3">

          <table class="table table-bordered table-striped align-middle">

            <thead class="table-dark">

              <tr>
                <th>Name</th>
                <th>Image</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Category</th>
                <th>Actions</th>
              </tr>

            </thead>

            <tbody>

              <% for (let i = 0; i < products.length; i++) { %>

                <tr>

                  <td>
                    <%= products[i].name %>
                  </td>

                  <td>

                    <% if (products[i].image) { %>

                      <img
                        src="/images/<%= products[i].image %>"
                        alt="<%= products[i].name %>"
                        class="product-image">

                    <% } else { %>

                      <span class="text-muted">
                        No image
                      </span>

                    <% } %>

                  </td>

                  <td>
                    $<%= products[i].price %>
                  </td>

                  <td>
                    <%= products[i].quantity %>
                  </td>

                  <td>
                    <%= products[i].category %>
                  </td>

                  <td>

                    <a
                      href="/product/<%= products[i].product_id %>"
                      class="btn btn-info btn-sm">

                      <i class="bi bi-eye"></i>
                      View

                    </a>

                    <% if (
                      user &&
                      (
                        user.role === 'admin' ||
                        (
                          user.role === 'seller' &&
                          products[i].seller_id == user.user_id
                        )
                      )
                    ) { %>

                      <a
                        href="/editProduct/<%= products[i].product_id %>"
                        class="btn btn-warning btn-sm">

                        <i class="bi bi-pencil"></i>
                        Edit

                      </a>

                      <a
                        href="/deleteProduct/<%= products[i].product_id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Are you sure you want to delete this product?')">

                        <i class="bi bi-trash"></i>
                        Delete

                      </a>

                    <% } %>

                  </td>

                </tr>

              <% } %>

            </tbody>

          </table>

        </div>

      <% } else { %>

        <div class="alert alert-warning mt-3">

          <i class="bi bi-exclamation-triangle me-2"></i>

          No matching products were found.

        </div>

      <% } %>

      <a
        href="/products"
        class="btn btn-outline-dark">

        <i class="bi bi-arrow-left"></i>
        Back to Listings

      </a>

    </div>

  </div>

</body>

</html>