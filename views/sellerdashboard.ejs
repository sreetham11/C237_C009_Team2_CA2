<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seller Dashboard - ResellVault</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <link
    href="/style.css"
    rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <%- include('partials/sidebar') %>

  <div class="content">
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% for (let i = 0; i < messages.length; i++) { %>
          <p class="mb-0"><%= messages[i] %></p>
        <% } %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% for (let i = 0; i < errors.length; i++) { %>
          <p class="mb-0"><%= errors[i] %></p>
        <% } %>
      </div>
    <% } %>

    <div class="page-section text-center">
      <h1>Seller Dashboard</h1>
      <p>Welcome, <%= user.username %> (<%= user.role %>)</p>

      <img
        src="/images/default-pfp.png"
        alt="Profile Picture"
        class="profile-pic mt-3">

      <div class="mt-4">
        <a href="/products/new" class="btn btn-success me-2">
          Add Product
        </a>

        <a href="/products" class="btn btn-primary me-2">
          Manage Listings
        </a>

        <a href="/searchProducts" class="btn btn-outline-primary">
          Search Products
        </a>
      </div>
    </div>
  </div>
</body>
</html>